\":\\\"$undefined\\\",\\\"iconNode\\\":[[\\\"circle\\\",{\\\"cx\\\":\\\"12\\\",\\\"cy\\\":\\\"12\\\",\\\"r\\\":\\\"10\\\",\\\"key\\\":\\\"1mglay\\\"}],[\\\"path\\\",{\\\"d\\\":\\\"M12 6v6l4 2\\\",\\\"key\\\":\\\"mmk7yg\\\"}]],\\\"className\\\":\\\"lucide-clock h-4 w-4\\\"}],\\\"1 min read\\\"]}],[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"flex flex-wrap gap-2\\\",\\\"children\\\":[[\\\"$\\\",\\\"span\\\",\\\"personal\\\",{\\\"className\\\":\\\"text-xs px-2 py-0.5 rounded-full bg-muted text-muted-foreground\\\",\\\"children\\\":\\\"personal\\\"}],[\\\"$\\\",\\\"span\\\",\\\"behind-the-scenes\\\",{\\\"className\\\":\\\"text-xs px-2 py-0.5 rounded-full bg-muted text-muted-foreground\\\",\\\"children\\\":\\\"behind-the-scenes\\\"}]]}]]}]]}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"prose prose-slate dark:prose-invert max-w-none prose-lg prose-headings:font-serif prose-headings:text-2xl prose-headings:mt-10 prose-headings:mb-4 prose-a:text-primary prose-img:rounded-xl prose-li:marker:text-primary\\\",\\\"children\\\":[[\\\"$\\\",\\\"p\\\",\\\"p-0\\\",{\\\"children\\\":[\\\"Every great kitchen has a story. This one starts with a question: \\\",[\\\"$\\\",\\\"strong\\\",\\\"strong-0\\\",{\\\"children\\\":\\\"why do we cook the way we do?\\\"}]]}],\\\"\\\\n\\\",[\\\"$\\\",\\\"p\\\",\\\"p-1\\\",{\\\"children\\\":[\\\"I grew up in a house where food was love. My grandmother never used a recipe — she cooked by feel, by taste, by memory. A pinch of this, a handful of that, and somehow it was always perfect. When I asked her how she did it, she'd smile and say, \\\\\\\"That's \\\",[\\\"$\\\",\\\"em\\\",\\\"em-0\\\",{\\\"children\\\":\\\"my\\\"}],\\\" way.\\\\\\\"\\\"]}],\\\"\\\\n\\\",[\\\"$\\\",\\\"p\\\",\\\"p-2\\\",{\\\"children\\\":\\\"Years later, living in my own apartment with a tiny kitchen and even tinier budget, I realized something. The recipes I was finding online were either:\\\"}],\\\"\\\\n\\\",[\\\"$\\\",\\\"ol\\\",\\\"ol-0\\\",{\\\"children\\\":[\\\"\\\\n\\\",[\\\"$\\\",\\\"li\\\",\\\"li-0\\\",{\\\"children\\\":\\\"Overcomplicated (13 ingredients for Tuesday night dinner? No thanks.)\\\"}],\\\"\\\\n\\\",[\\\"$\\\",\\\"li\\\",\\\"li-1\\\",{\\\"children\\\":\\\"Watered down (where's the flavor?)\\\"}],\\\"\\\\n\\\",[\\\"$\\\",\\\"li\\\",\\\"li-2\\\",{\\\"children\\\":\\\"Gatekept behind \\\\\\\"secret\\\\\\\" techniques\\\"}],\\\"\\\\n\\\"]}],\\\"\\\\n\\\",[\\\"$\\\",\\\"p\\\",\\\"p-3\\\",{\\\"children\\\":[\\\"So I started doing what my grandmother did — taking the food I loved and making it \\\",[\\\"$\\\",\\\"em\\\",\\\"em-0\\\",{\\\"children\\\":\\\"my way\\\"}],\\\".\\\"]}],\\\"\\\\n\\\",[\\\"$\\\",\\\"h2\\\",\\\"h2-0\\\",{\\\"children\\\":\\\"The Philosophy\\\"}],\\\"\\\\n\\\",[\\\"$\\\",\\\"p\\\",\\\"p-4\\\",{\\\"children\\\":[[\\\"$\\\",\\\"strong\\\",\\\"strong-0\\\",{\\\"children\\\":\\\"Appropriated Kitchen\\\"}],\\\" isn't about cultural appropriation — it's about \\\",[\\\"$\\\",\\\"em\\\",\\\"em-0\\\",{\\\"children\\\":\\\"culinary appreciation\\\"}],\\\". It's the belief that great food belongs to everyone, and that the best recipes are the ones you make your own.\\\"]}],\\\"\\\\n\\\",[\\\"$\\\",\\\"ul\\\",\\\"ul-0\\\",{\\\"children\\\":[\\\"\\\\n\\\",[\\\"$\\\",\\\"li\\\",\\\"li-0\\\",{\\\"children\\\":[[\\\"$\\\",\\\"strong\\\",\\\"strong-0\\\",{\\\"children\\\":\\\"Take what you love.\\\"}],\\\" Find dishes that excite you.\\\"]}],\\\"\\\\n\\\",[\\\"$\\\",\\\"li\\\",\\\"li-1\\\",{\\\"children\\\":[[\\\"$\\\",\\\"strong\\\",\\\"strong-0\\\",{\\\"children\\\":\\\"Learn the why.\\\"}],\\\" Understand the technique, not just the steps.\\\"]}],\\\"\\\\n\\\",[\\\"$\\\",\\\"li\\\",\\\"li-2\\\",{\\\"children\\\":[[\\\"$\\\",\\\"strong\\\",\\\"strong-0\\\",{\\\"children\\\":\\\"Make it yours.\\\"}],\\\" Adjust, experiment, break the rules.\\\"]}],\\\"\\\\n\\\"]}],\\\"\\\\n\\\",[\\\"$\\\",\\\"h2\\\",\\\"h2-1\\\",{\\\"children\\\":\\\"What to Expect\\\"}],\\\"\\\\n\\\",[\\\"$\\\",\\\"p\\\",\\\"p-5\\\",{\